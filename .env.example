# ================================
# LLM (OpenAI-compatible API)
# ================================
# Ollama: http://host.docker.internal:11434/v1
# LM Studio: http://host.docker.internal:1234/v1
# vLLM: http://host.docker.internal:8080/v1
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2:3b
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
# tool_choice: "auto"=모델 자율 선택 (Ollama 기본), "required"=첫 호출 강제 (Gemma4/vLLM)
LLM_TOOL_CHOICE=auto

# ================================
# Embeddings (OpenAI-compatible)
# ================================
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=1024
# 임베딩 모델 토크나이저와 tiktoken 간 차이를 감안해 max_context(512) 미만으로 설정
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ================================
# Database
# ================================
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragdb
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@postgres:5432/ragdb

# ================================
# Redis
# ================================
REDIS_URL=redis://redis:6379
REDIS_SESSION_TTL=3600

# ================================
# App
# ================================
APP_PREFIX=/rag

# 대화 암호화 MEK 파생 키 — 최소 32자 랜덤 문자열 (변경 시 기존 암호문 복호화 불가)
# 생성 예시: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key-min-32-chars

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-random-secret-min-32-chars  # 선택: 미설정 시 ADMIN_PASSWORD 사용

# 관리자 API 토큰 (FastAPI admin/tenant 엔드포인트 보호용, 최소 32자)
ADMIN_API_TOKEN=change-me-to-a-random-token-min-32-chars
# Next.js 관리자 UI에서 사용 (브라우저에 노출되므로 ADMIN_PASSWORD와 다른 값 사용)
NEXT_PUBLIC_ADMIN_API_TOKEN=change-me-to-a-random-token-min-32-chars

# ================================
# 다국어
# ================================
DEFAULT_LANGUAGE=ko
SUPPORTED_LANGUAGES=ko,en,ja,zh,es,fr,de,pt,vi,th

# ================================
# Rate Limiting (per tenant, per minute)
# ================================
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ================================
# 파일 업로드
# ================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ================================
# Jina Reader (URL 인제스트)
# https://jina.ai 에서 API 키 발급
# 미설정 시 무료 플랜 사용 (rate limit 있음)
# ================================
JINA_API_KEY=

# ================================
# Safeguard (kanana-safeguard-prompt-2.1b)
# 사용자 입력을 LLM 호출 전에 안전 검사하는 레이어.
#
# [배포 방식별 주소 예시]
#   docker-compose 내부 서비스 : http://safeguard:8001/v1
#   로컬 vLLM (호스트 직접)   : http://localhost:8001/v1
#   Docker → 호스트 vLLM      : http://host.docker.internal:8001/v1
#   원격 서버                  : http://192.168.1.100:8001/v1
#
# [포트 변경 시]
#   아래 SAFEGUARD_BASE_URL의 포트를 바꾸고,
#   docker-compose.yml safeguard 서비스의 --port 와 ports 매핑도 함께 변경.
#
# [vLLM 기동 예시 (독립 실행)]
#   vllm serve kakaocorp/kanana-safeguard-prompt-2.1b \
#     --port 8001 --max-model-len 4096 --dtype bfloat16
# ================================
SAFEGUARD_ENABLED=false

# vLLM 서버 주소 (포트 포함)
SAFEGUARD_BASE_URL=http://safeguard:8001/v1

# vLLM API 키 (vLLM은 기본적으로 인증 없음 → "none" 유지)
SAFEGUARD_API_KEY=none

# 모델명 — vLLM --model 인자와 반드시 일치해야 함
SAFEGUARD_MODEL=kakaocorp/kanana-safeguard-prompt-2.1b

# 차단 시 사용자에게 보낼 고정 메시지
SAFEGUARD_BLOCKED_MESSAGE=**UNSAFE** 죄송합니다. 해당 메시지는 처리할 수 없습니다.

# safeguard 서버 장애 시 동작: true=허용(fail-open) / false=차단(fail-closed)
SAFEGUARD_FAIL_OPEN=true

# ================================
# Reranker (cross-encoder, 로컬 모델)
# 검색된 청크를 LLM 전달 전에 cross-encoder로 재순위하여 품질 향상.
# sentence-transformers + torch(CUDA) 필요 → requirements.txt 참고.
#
# [모델 예시]
#   dragonkue/bge-reranker-v2-m3-ko  — 한국어 최적화, Apache 2.0, 권장
#   BAAI/bge-reranker-v2-m3           — 다국어(90+), Apache 2.0
#   upskyy/ko-reranker                — 한국어, MIT
#
# [디바이스]
#   cuda   — GPU (권장)
#   cpu    — CPU (느림)
#   cuda:0 — 특정 GPU 지정
# ================================
RERANKER_ENABLED=false
RERANKER_MODEL=dragonkue/bge-reranker-v2-m3-ko
RERANKER_TOP_N=3
RERANKER_DEVICE=cuda

# ================================
# PII Masker (NER, 로컬 모델)
# 사용자 메시지에서 개인정보(이름·주소·전화·이메일 등)를 자동 탐지·마스킹.
#
# [활성화 방법] — 테넌트별 설정 (PATCH API로 변경)
#   curl -X PATCH http://localhost:3000/rag/api/v1/admin/tenants/{ID} \
#     -u admin:비밀번호 -H "Content-Type: application/json" \
#     -d '{"pii_config": {"enabled": true, "types": ["NAME","ADDRESS","PHONE","EMAIL","SSN","CARD","BRN"]}}'
#
# [NER 모델] — 서버 전역 설정
#   monologg/koelectra-base-finetuned-naver-ner  — 한국어 NER 전용 (권장)
#   klue/bert-base                               — KLUE-NER 벤치마크 모델
#
# [디바이스]
#   cpu    — CPU (기본값)
#   cuda   — GPU (추론 속도 향상)
#   cuda:0 — 특정 GPU 지정
# ================================
PII_NER_MODEL=monologg/koelectra-base-finetuned-naver-ner
PII_NER_DEVICE=cpu
